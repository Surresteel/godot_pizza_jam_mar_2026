#===============================================================================
#	CLASS PROPERTIES:
#===============================================================================
class_name Opioid
extends Item


#===============================================================================
#	CLASS MEMBERS:
#===============================================================================
# TRAITS:
var stat_multi: float = 1.5


#===============================================================================
#	CALLBACKS:
#===============================================================================
# Node Initialisation:
func _ready() -> void:
	item_name = "Opioid"


#===============================================================================
#	FUNCTIONS - ITEM:
#===============================================================================
# Gets the target to take drugs:
func use(_user: Node = null, target: Node = null) -> void:
	# GATE - target must exist:
	if not target or not target.has_method("take_drugs"):
		return
	
	target.take_drugs(self)
