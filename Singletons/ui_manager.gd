#===============================================================================
#	CLASS PROPERTIES:
#===============================================================================
extends Node


#===============================================================================
#	CLASS MEMBERS:
#===============================================================================
# UI:
var ui: UserInterface = null


#===============================================================================
#	FUNCTIONS - UI:
#===============================================================================
# Updates the interact prompt:
func update_interact_prompt(msg: String = "", vis: bool = true) -> void:
	# GATE - ui reference must exist:
	if not ui:
		return
	
	ui.update_interact_prompt(msg, vis)
